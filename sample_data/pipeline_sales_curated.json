{
  "name": "Sales Curated Pipeline",
  "description": "Join raw sales and customers, then publish a curated Delta table.",
  "status": "draft",
  "definition": {
    "nodes": [
      {
        "id": "fileSource_sales",
        "type": "fileSource",
        "position": { "x": 40, "y": 120 },
        "data": {
          "label": "Sales Source",
          "config": { "fileId": "<replace-with-sales-file-id>" }
        }
      },
      {
        "id": "fileSource_customers",
        "type": "fileSource",
        "position": { "x": 40, "y": 320 },
        "data": {
          "label": "Customers Source",
          "config": { "fileId": "<replace-with-customers-file-id>" }
        }
      },
      {
        "id": "join_customers",
        "type": "join",
        "position": { "x": 360, "y": 220 },
        "data": {
          "label": "Join Customers",
          "config": {
            "joinType": "left",
            "leftKey": "customer_id",
            "rightKey": "customer_id"
          }
        }
      },
      {
        "id": "write_delta_sales",
        "type": "writeDelta",
        "position": { "x": 700, "y": 220 },
        "data": {
          "label": "Publish Curated",
          "config": {
            "tableName": "sales_curated",
            "mode": "overwrite",
            "schemaName": "analytics"
          }
        }
      }
    ],
    "edges": [
      { "id": "edge_1", "source": "fileSource_sales", "target": "join_customers" },
      { "id": "edge_2", "source": "fileSource_customers", "target": "join_customers" },
      { "id": "edge_3", "source": "join_customers", "target": "write_delta_sales" }
    ]
  }
}
